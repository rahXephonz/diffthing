{
  "name": "diffthing-monorepo",
  "private": true,
  "scripts": {
    "web:dev": "pnpm --filter diffthing-web dev",
    "web:build": "pnpm --filter diffthing-web build",
    "web:lint": "pnpm --filter diffthing-web lint",
    "web:format": "pnpm --filter diffthing-web format",
    "daemon:test": "cargo test --workspace",
    "daemon:run": "cargo run -p diffthing",
    "daemon:fmt": "cargo fmt --all",
    "daemon:fmt:check": "cargo fmt --all -- --check",
    "daemon:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "changeset": "changeset",
    "changeset:version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "lefthook": "^2.1.10"
  }
}
